@using BolaoDaCopa2026.Models
@using BolaoDaCopa2026.Models.ViewModels
@model HomeViewModel

@{
    ViewData["Title"] = "Home";
    var agora = DateTime.Now;

    var jogosHoje = Model.Jogos
        .Where(j => j.Jogo.DataHora.Date == agora.Date)
        .OrderBy(j => j.Jogo.DataHora)
        .Take(4)
        .ToList();

    var exibirJogos = jogosHoje.Any()
        ? jogosHoje
        : Model.Jogos
            .Where(j => j.Jogo.DataHora > agora)
            .OrderBy(j => j.Jogo.DataHora)
            .Take(4)
            .ToList();

    var proximoJogo = Model.Jogos
        .Where(j => j.Jogo.DataHora > agora)
        .OrderBy(j => j.Jogo.DataHora)
        .FirstOrDefault();

    var campeao = ViewBag.Campeao as Selecao;
}

@functions {
    public string SiglaSelecao(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
            return "";

        nome = nome.Trim().ToUpper();

        return nome.Length >= 3
            ? nome.Substring(0, 3)
            : nome;
    }
}

@if (ViewBag.AvisoCampeao == true)
{
    <div class="alert-campeao">
        ⚠️ Você ainda não escolheu o campeão da Copa.
        <a href="/Apostas/Campeao">Escolher agora</a>
    </div>
}

@if (campeao != null)
{
    <div class="campeao-escolhido">
        <span>Seu campeão:</span>
        <img src="@campeao.BandeiraUrl" />
        <strong>@campeao.Nome</strong>
        <a asp-controller="Apostas"
           asp-action="Campeao"
           class="btn-trocar">
            alterar
        </a>
    </div>
}

<section class="landing">

    <div class="landing_card">

        @if (Context.Session.GetString("IsAdmin")?.Equals("True", StringComparison.OrdinalIgnoreCase) == true)
        {
            <div class="admin-link-wrap">
                <a asp-controller="AdminJogos"
                   asp-action="Index"
                   class="admin-link">
                    Administrador
                </a>
            </div>
        }

        <h1>Bolão da Copa 2026</h1>

        <h2 class="games-label">
            @if (jogosHoje.Any())
            {
                <span class="status-hoje">📅 Jogos de Hoje</span>
            }
            else
            {
                <span class="status-proximos">⏳ Próximos Jogos</span>
            }
        </h2>

        @if (exibirJogos.Any())
        {
            <div class="games-wrapper">

                @foreach (var item in exibirJogos)
                {
                    var jogo = item.Jogo;
                    var aposta = item.ApostaUsuario;

                    var finalizado = jogo.Status == "Finalizado";
                    var emAndamento = jogo.Status == "EmAndamento";
                    var usuarioLogado = Context.Session.GetInt32("ApostadorId") != null;
                    var podeAbrirApostas = usuarioLogado && (finalizado || emAndamento);

                    <div class="game-card @(podeAbrirApostas ? "game-card--clickable" : "")">

                        <div class="game-meta">
                            <span class="fase">@jogo.Fase</span>
                            <span class="datetime">@jogo.DataHora.ToString("dd/MM • HH:mm")</span>

                            @if (emAndamento)
                            {
                                <span class="live">AO VIVO</span>
                            }
                        </div>

                        <div class="matchup">

                            <div class="team" title="@jogo.SelecaoA.Nome">
                                <img src="@jogo.SelecaoA.BandeiraUrl" alt="@jogo.SelecaoA.Nome" />
                                <span>@SiglaSelecao(jogo.SelecaoA.Nome)</span>
                            </div>

                            @if (finalizado || emAndamento)
                            {
                                <div class="score">
                                    <span>@jogo.GolsSelecaoA</span>
                                    <span class="score-divider">–</span>
                                    <span>@jogo.GolsSelecaoB</span>
                                </div>
                            }
                            else
                            {
                                <div class="vs">×</div>
                            }

                            <div class="team" title="@jogo.SelecaoB.Nome">
                                <img src="@jogo.SelecaoB.BandeiraUrl" alt="@jogo.SelecaoB.Nome" />
                                <span>@SiglaSelecao(jogo.SelecaoB.Nome)</span>
                            </div>

                        </div>

                        <div class="bet-box">

                            @if (aposta != null)
                            {
                                <span class="bet-label">Sua aposta</span>
                                <span class="bet-score">
                                    @aposta.GolsSelecaoA – @aposta.GolsSelecaoB
                                </span>
                            }
                            else
                            {
                                <span class="bet-missing">
                                    ⚠ Falta sua aposta
                                </span>
                            }

                        </div>

                        @if (podeAbrirApostas)
                        {
                            <a asp-controller="Home"
                               asp-action="ApostasJogo"
                               asp-route-id="@jogo.Id"
                               class="game-link-overlay"
                               aria-label="Ver apostas deste jogo"></a>
                        }

                    </div>
                }

            </div>
        }

        @if (proximoJogo != null)
        {
            <div class="countdown"
                 data-date="@proximoJogo.Jogo.DataHora.ToString("yyyy-MM-ddTHH:mm:ss")">

                <div class="time-box">
                    <div class="time-value days">00</div>
                    <div class="time-label">Dias</div>
                </div>

                <div class="time-box">
                    <div class="time-value hours">00</div>
                    <div class="time-label">Horas</div>
                </div>

                <div class="time-box">
                    <div class="time-value minutes">00</div>
                    <div class="time-label">Min</div>
                </div>

                <div class="time-box">
                    <div class="time-value seconds">00</div>
                    <div class="time-label">Seg</div>
                </div>

            </div>
        }

        <div class="actions">

            @if (Context.Session.GetInt32("ApostadorId") == null)
            {
                <a class="btn-home btn-home--primary"
                   asp-controller="Conta"
                   asp-action="Login">
                    Entrar no Bolão
                </a>
            }
            else
            {
                <a href="/Apostas" class="btn-home btn-home--primary">
                    Minhas Apostas
                </a>

                <a asp-controller="Ranking"
                   asp-action="Index"
                   class="btn-home btn-home--primary">
                    Ranking
                </a>
            }

            <a href="/Selecoes" class="btn-home btn-home--primary">
                Tabela da Copa
            </a>

            <a asp-controller="Home"
               asp-action="Regras"
               class="btn-home btn-home--primary">
                Regras do Bolão
            </a>

        </div>

    </div>

</section>

<script>
    function updateCountdowns() {

        document.querySelectorAll(".countdown").forEach(countdown => {

            const targetDate = new Date(countdown.dataset.date).getTime();
            const now = Date.now();
            const diff = targetDate - now;

            const daysEl = countdown.querySelector(".days");
            const hoursEl = countdown.querySelector(".hours");
            const minutesEl = countdown.querySelector(".minutes");
            const secondsEl = countdown.querySelector(".seconds");

            if (diff <= 0) {
                daysEl.textContent =
                hoursEl.textContent =
                minutesEl.textContent =
                secondsEl.textContent = "00";

                return;
            }

            daysEl.textContent = String(Math.floor(diff / (1000 * 60 * 60 * 24))).padStart(2, "0");
            hoursEl.textContent = String(Math.floor((diff / (1000 * 60 * 60)) % 24)).padStart(2, "0");
            minutesEl.textContent = String(Math.floor((diff / (1000 * 60)) % 60)).padStart(2, "0");
            secondsEl.textContent = String(Math.floor((diff / 1000) % 60)).padStart(2, "0");

        });

    }

    updateCountdowns();
    setInterval(updateCountdowns, 1000);
</script>

<style>

    /* =========================
               ALERTA DO CAMPEÃO
               ========================= */
    .alert-campeao {
        width: fit-content;
        max-width: calc(100% - 32px);
        margin: 0 auto 18px auto;
        text-align: center;
    }

    /* =========================
               DESKTOP SEM SCROLL
               ========================= */
    @@media (min-width: 701px) {
        html, body {
            overflow-y: hidden;
        }

        .landing {
            min-height: calc(100vh - 40px);
            display: flex;
            align-items: center;
            justify-content: center;
        }
    }

    .landing_card {
        position: relative;
        overflow: visible;
    }

    /* =========================
               BOTÃO ADMIN
               ========================= */
    .admin-link-wrap {
        position: absolute;
        top: -58px;
        left: 0;
        z-index: 999;
    }

    .admin-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        border-radius: 12px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.78);
        text-decoration: none;
        font-weight: 700;
        transition: filter .2s ease, transform .1s ease, background .2s ease;
    }

        .admin-link:hover {
            color: rgba(255,255,255,0.90);
            background: rgba(255,255,255,0.10);
            filter: brightness(1.05);
            transform: translateX(-2px);
            text-decoration: none;
        }

    /* =========================
               JOGOS
               ========================= */
    .games-wrapper {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
    }

    .game-card {
        position: relative;
        padding: 18px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .game-card--clickable {
        transition: transform .2s ease, border-color .2s ease;
    }

        .game-card--clickable:hover {
            transform: translateY(-3px);
            border-color: rgba(255, 203, 0, .5);
        }

    .game-link-overlay {
        position: absolute;
        inset: 0;
        border-radius: 16px;
        z-index: 2;
    }

    .game-meta {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        opacity: .7;
        margin-bottom: 8px;
    }

    .fase {
        font-weight: 700;
        font-size: 12px;
    }

    .datetime {
        font-size: 12px;
    }

    .live {
        color: #ff4d4d;
        font-weight: 800;
    }

    .matchup {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin-top: 10px;
    }

    /* =========================
               BALÕES DAS SELEÇÕES
               ========================= */
    .team {
        width: 170px;
        min-height: 54px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 16px;
        border-radius: 14px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        text-align: center;
        box-sizing: border-box;
    }

        .team span {
            display: inline-block;
            line-height: 1.2;
            font-weight: 700;
            letter-spacing: .5px;
        }

        .team img {
            height: 22px;
            flex-shrink: 0;
        }

    .score {
        display: flex;
        gap: 6px;
        font-size: 22px;
        font-weight: 900;
        padding: 4px 12px;
        border-radius: 10px;
        background: rgba(0, 0, 0, .35);
    }

    .score-divider {
        opacity: .5;
    }

    .vs {
        font-size: 20px;
        opacity: .5;
        font-weight: 900;
    }

    .bet-box {
        margin-top: 12px;
        display: flex;
        justify-content: center;
        font-size: 13px;
    }

    .bet-label {
        margin-right: 6px;
        opacity: .6;
    }

    .bet-score {
        font-weight: 800;
    }

    .bet-missing {
        color: #ffcc00;
        font-weight: 700;
    }

    .countdown {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 24px;
    }

    .time-box {
        width: 70px;
        text-align: center;
    }

    .time-value {
        font-size: 22px;
        font-weight: 900;
    }

    .time-label {
        font-size: 11px;
        opacity: .7;
    }

    .actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-home {
        display: flex;
        justify-content: center;
        padding: 12px;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
    }

    .btn-home--primary {
        background: #ffcb00;
        color: #0b0f17 !important;
    }

        .btn-home--primary:hover,
        .btn-home--primary:focus,
        .btn-home--primary:active,
        .btn-home--primary:visited {
            color: #0b0f17 !important;
            transform: translateY(-2px);
            filter: brightness(1.05);
            text-decoration: none !important;
        }

    @@media (min-width:700px) {
        .games-wrapper {
            grid-template-columns: 1fr 1fr;
        }

        .actions {
            flex-direction: row;
            flex-wrap: wrap;
        }

        .btn-home {
            flex: 1;
        }
    }

    @@media (max-width:700px) {
        .landing {
            padding-top: 28px;
        }

        .matchup {
            flex-direction: column;
            gap: 8px;
        }

        .team {
            width: 100%;
            max-width: 240px;
            justify-content: center;
        }

        .score {
            font-size: 18px;
            padding: 2px 12px;
        }

        .countdown {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            justify-items: center;
            margin-top: 24px;
        }

        .time-box {
            width: 100%;
            max-width: 58px;
        }

        .time-value {
            font-size: 18px;
        }

        .time-label {
            font-size: 10px;
        }

        .admin-link-wrap {
            top: -48px;
            left: 0;
        }

        .landing_card {
            margin-top: 32px;
        }
    }

</style>
