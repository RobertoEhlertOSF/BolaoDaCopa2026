    }

    .jogo-acao {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        min-width: 0;
    }

    .palpite {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .placar {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .placar input {
            width: 44px;
            height: 38px;
            text-align: center;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(0,0,0,0.45);
            color: white;
        }

    .x {
        font-weight: bold;
        opacity: 0.8;
    }

    .resultado-fechado {
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .pontos {
        font-weight: bold;
        white-space: nowrap;
    }

    .pontos-exato {
        color: green;
    }

    .pontos-parcial {
        color: orange;
    }

    .pontos-minimo {
        color: #555;
    }

    .pontos-neutro {
        color: #999;
    }

    .btn-salvar {
        margin-left: 0;
        padding: 10px 16px;
        border-radius: 10px;
        border: 2px solid rgba(255,203,0,0.9);
        background: transparent;
        color: rgba(255,203,0,0.95);
        font-weight: 800;
        cursor: pointer;
        transition: filter 0.2s ease, transform 0.1s ease, background 0.2s ease, color 0.2s ease;
        min-width: 110px;
    }

        .btn-salvar:hover {
            background: rgba(255,203,0,0.95);
            color: #0b0f17;
            filter: brightness(1.05);
            transform: translateY(-2px);
        }

    @@media (max-width:900px) {
        .top-actions {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
