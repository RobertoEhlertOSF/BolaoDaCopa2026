@model IEnumerable<BolaoDaCopa2026.Models.Jogo>
@using BolaoDaCopa2026.Models

<!-- ====== AÇÕES TOPO (Voltar / Regras) ====== -->
<div class="top-actions">
    <a asp-controller="Home"
       asp-action="Index"
       class="btn-voltar">
        ← Voltar para o início
    </a>

    <a asp-controller="Home"
       asp-action="Regras"
       class="btn-regras">
        Regras do bolão
    </a>
</div>

@{
    var apostas = ViewBag.Apostas as List<Aposta>;
    var pontuacaoService = new PontuacaoService();

    var filtro = (string)(ViewBag.Filtro ?? "todos");
    var grupo = (string)(ViewBag.Grupo ?? "");
    var fase = (string)(ViewBag.Fase ?? "Grupo A");

    var fases = new List<string>
    {
        "Grupo A","Grupo B","Grupo C","Grupo D","Grupo E","Grupo F",
        "Grupo G","Grupo H","Grupo I","Grupo J","Grupo K","Grupo L",
        "Segunda Fase","Oitavas","Quartas","Semifinal","Terceiro Lugar", "Final"
    };

    var indiceAtual = fases.IndexOf(fase);

    var faseAnterior = fases[
        indiceAtual == 0
            ? fases.Count - 1
            : indiceAtual - 1
    ];

    var proximaFase = fases[
        indiceAtual == fases.Count - 1
            ? 0
            : indiceAtual + 1
    ];
}

<header>
    <h1>Meus Palpites</h1>
</header>

<!-- ====== NAVEGAÇÃO DE FASE ====== -->
<div class="fase-nav">

    @if (faseAnterior != null)
    {
        <a class="fase-btn"
           asp-action="Index"
           asp-route-fase="@faseAnterior"
           asp-route-filtro="@filtro"
           asp-route-grupo="@grupo">‹</a>
    }
    else
    {
        <button class="fase-btn" disabled>‹</button>
    }

    <div class="fase-titulo">@fase</div>

    @if (proximaFase != null)
    {
        <a class="fase-btn"
           asp-action="Index"
           asp-route-fase="@proximaFase"
           asp-route-filtro="@filtro"
           asp-route-grupo="@grupo">›</a>
    }
    else
    {
        <button class="fase-btn" disabled>›</button>
    }

</div>

<div class="container">

    <!-- ====== FILTROS ====== -->
    <form method="get" class="filtros">

        <input type="hidden" name="fase" value="@fase" />

        <select name="filtro">
            <option value="todos" selected="@(filtro == "todos")">Mostrar todos</option>
            <option value="com" selected="@(filtro == "com")">Somente com palpite</option>
            <option value="sem" selected="@(filtro == "sem")">Somente sem palpite</option>
        </select>

        <button type="submit" class="btn-filtro">Aplicar</button>
    </form>

    @foreach (var jogo in Model.OrderBy(j => j.DataHora))
    {
        var aposta = apostas?.FirstOrDefault(a => a.JogoId == jogo.Id);

        int pontos = 0;
        string classePontos = "pontos-neutro";

        if (!jogo.EstaAberto && aposta != null)
        {
            pontos = pontuacaoService.CalcularPontuacaoApostador(
            jogo.GolsSelecaoA ?? 0,
            jogo.GolsSelecaoB ?? 0,
            aposta.GolsSelecaoA,
            aposta.GolsSelecaoB
            );

            if (pontos == 10) classePontos = "pontos-exato";
            else if (pontos == 7 || pontos == 5) classePontos = "pontos-parcial";
            else if (pontos == 2) classePontos = "pontos-minimo";
        }

        <div class="jogo @(jogo.EstaAberto ? "aberto" : "encerrado")">

            <div class="times">

                <div class="time">
                    <img src="@(jogo.SelecaoA?.BandeiraUrl ?? "https://placehold.co/80x50?text=--")" />
                    @(jogo.SelecaoA?.Nome ?? "A definir")
                </div>

                <span class="vs">vs</span>

                <div class="time">
                    <img src="@(jogo.SelecaoB?.BandeiraUrl ?? "https://placehold.co/80x50?text=--")" />
                    @(jogo.SelecaoB?.Nome ?? "A definir")
                </div>

            </div>

            <div class="info">
                @jogo.DataHora.ToString("dd/MM HH:mm")
            </div>

            <div class="acao">

                @if (jogo.EstaAberto)
                {
                    <form asp-action="Salvar" method="post" class="palpite">

                        <input type="hidden" name="fase" value="@fase" />
                        <input type="hidden" name="filtro" value="@filtro" />
                        <input type="hidden" name="grupo" value="@grupo" />
                        <input type="hidden" name="jogoId" value="@jogo.Id" />

                        <div class="placar">

                            <input type="number"
                                   name="golsSelecaoA"
                                   min="0"
                                   value="@aposta?.GolsSelecaoA" />

                            <span class="x">x</span>

                            <input type="number"
                                   name="golsSelecaoB"
                                   min="0"
                                   value="@aposta?.GolsSelecaoB" />

                        </div>

                        <button class="btn btn-salvar">
                            @(aposta == null ? "Salvar" : "Atualizar")
                        </button>

                    </form>
                }
                else
                {
                    <div class="placar">
                        <strong>@aposta?.GolsSelecaoA</strong>
                        <span class="x">x</span>
                        <strong>@aposta?.GolsSelecaoB</strong>

                        @if (aposta != null)
                        {
                            <span class="pontos @classePontos">(@pontos pts)</span>
                        }
                    </div>
                }

            </div>

        </div>
    }

</div>

<style>
    /* ===== filtros ===== */ .filtros {
        margin: 18px 0 26px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }

        .filtros select {
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.18);
            color: #fff;
            outline: none;
        }

            .filtros select option {
                color: #000;
                background: #fff;
            }

    .btn-filtro {
        padding: 10px 16px;
        border-radius: 10px;
        cursor: pointer;
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17;
        border: none;
        font-weight: 800;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-filtro:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
        }
    /* ===== seu CSS original ===== */

    .placar {
        font-size: 1.2rem;
        margin-top: 0.5rem;
    }

    .x {
        margin: 0 0.5rem;
        font-weight: bold;
    }

    .pontos {
        margin-left: 1rem;
        font-weight: bold;
    }

    .pontos-exato {
        color: green;
    }

    .pontos-parcial {
        color: orange;
    }

    .pontos-minimo {
        color: #555;
    }

    .pontos-neutro {
        color: #999;
    }

    .palpite input {
        width: 50px;
        text-align: center;
    }

    .btn-salvar {
        margin-left: 10px;
    }
    /* ===== topo: voltar + regras ===== */

    .top-actions {
        max-width: 1100px;
        margin: 10px auto 18px;
        padding: 0 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .btn-voltar {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 10px;
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17;
        text-decoration: none;
        font-weight: 800;
        border: none;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-voltar:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
            color: #0b0f17;
            text-decoration: none;
        }

        .btn-voltar:focus, .btn-voltar:active {
            color: #0b0f17;
            text-decoration: none;
        }

    .btn-regras {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        border-radius: 10px;
        border: none;
        font-weight: 800;
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17 !important;
        opacity: 0.70;
        text-decoration: none !important;
    }

        .btn-regras:hover, .btn-regras:focus, .btn-regras:active {
            color: #0b0f17 !important;
            text-decoration: none !important;
        }
    /* ===== navegação de fases (estilo GE) ===== */

    .fase-nav {
        max-width: 1100px;
        margin: 8px auto 22px;
        padding: 0 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .fase-titulo {
        flex: 1;
        text-align: center;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #ffffff;
        opacity: 0.90;
        font-size: 1.05rem;
    }

    .fase-btn {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.85);
        font-size: 28px;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.55;
    }

    .jogo {
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        margin-bottom: 14px;
        border-radius: 16px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
    }
    /* ===== TIMES ===== */

    .times {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .time {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
    }

        .time img {
            width: 26px;
            height: 18px;
            object-fit: cover;
            border-radius: 3px;
        }
    /* ===== VS ===== */

    .vs {
        text-align: center;
        opacity: 0.6;
        font-weight: 700;
    }
    /* ===== DATA ===== */

    .info {
        text-align: center;
        opacity: 0.7;
    }
    /* ===== ÁREA PLACAR + BOTÃO ===== */

    .acao {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    /* ===== PLACAR ===== */

    .placar {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .placar input {
            width: 42px;
            height: 38px;
            text-align: center;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(0,0,0,0.45);
            color: white;
        }
    /* ===== BOTÃO ===== */

    .btn-salvar {
        padding: 10px 16px;
        border-radius: 10px;
        border: 2px solid rgba(255,203,0,0.9);
        background: transparent;
        color: rgba(255,203,0,0.95);
        font-weight: 800;
        cursor: pointer;
        transition: .2s;
    }

        .btn-salvar:hover {
            background: rgba(255,203,0,0.95);
            color: #0b0f17;
        }
    /* ===== Telas menores ===== */

    @@media (max-width:900px) {
        .jogo {
            grid-template-columns: 1fr;
            gap: 16px;
            text-align: center;
            padding: 20px;
        }
        /* FILTROS MOBILE */

        .filtros {
            flex-direction: column;
            align-items: center;
            gap: 14px;
        }

            .filtros select, .btn-filtro {
                width: 100%;
                max-width: 260px;
            }
        /* TIMES */

        .times {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .time {
            justify-content: center;
        }

        .vs {
            opacity: 0.6;
        }
        /* DATA */

        .info {
            text-align: center;
            font-size: 14px;
            opacity: 0.7;
        }
        /* FORM DO PALPITE */

        .palpite {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            width: 100%;
        }
        /* PLACAR */

        .placar {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

            .placar input {
                width: 46px;
                height: 40px;
                font-size: 16px;
            }
        /* BOTÃO */

        .btn-salvar {
            width: 140px;
            margin-left: 0;
        }

        @@media (max-width:900px) {
                .jogo {
                display: grid;
                grid-template-columns: 1fr;
                gap: 16px;
                text-align: center;
            }
        }
    }
</style>