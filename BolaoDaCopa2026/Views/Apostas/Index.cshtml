        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }
    }
   
    /* MOBILE: mantém scroll normal  */
    
    @@media (max-width: 900px) {
        html, body {
            overflow-y: auto;
        }
    }
    
    footer {
        display: none !important;
    }

    .apostas-container {
        max-width: 1120px;
        margin-bottom: 24px;
    }

    .lista-jogos {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
    }

    .filtros {
        margin: 18px 0 26px;
        display: flex;
