        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }

        .filtros select {
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.18);
            color: #fff;
            outline: none;
        }

            .filtros select option {
                color: #000;
                background: #fff;
            }

    .btn-filtro {
        padding: 10px 16px;
        border-radius: 10px;
        cursor: pointer;
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17;
        border: none;
        font-weight: 800;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-filtro:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
        }

    .top-actions {
        max-width: 1100px;
        margin: 10px auto 18px;
        padding: 0 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .top-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-voltar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 10px;
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17;
        text-decoration: none;
        font-weight: 800;
        border: none;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-voltar:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
            color: #0b0f17;
            text-decoration: none;
        }

        .btn-voltar:focus,
        .btn-voltar:active {
            color: #0b0f17;
            text-decoration: none;
        }

    .btn-campeao {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 800;
        text-decoration: none;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-campeao:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
            text-decoration: none;
        }

        .btn-campeao:focus,
        .btn-campeao:active {
            text-decoration: none;
        }

    .btn-regras {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        border-radius: 10px;
        border: none;
        font-weight: 800;
        background: rgba(255,203,0,0.95);
        color: #0b0f17 !important;
        text-decoration: none !important;
        transition: filter 0.2s ease, transform 0.1s ease;
    }

        .btn-regras:hover,
        .btn-regras:focus,
        .btn-regras:active {
            filter: brightness(1.05);
            transform: translateY(-2px);
            color: #0b0f17 !important;
            text-decoration: none !important;
        }

    header h1 {
        text-align: center;
        margin-bottom: 22px;
    }

    .fase-nav {
        max-width: 1100px;
        margin: 8px auto 22px;
        padding: 0 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .fase-titulo {
        flex: 1;
        text-align: center;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #ffffff;
        opacity: 0.90;
        font-size: 1.05rem;
    }

    .fase-btn {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        border: none;
        background: rgba(255,203,0,0.95);
        color: #0b0f17;
        font-size: 28px;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 800;
        transition: filter 0.2s ease, transform 0.1s ease;
        opacity: 1;
    }

        .fase-btn:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
            color: #0b0f17;
            text-decoration: none;
        }

        .fase-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
            transform: none;
            filter: none;
        }

    .jogo {
        display: grid;
        grid-template-columns: 90px minmax(0, 1fr) auto;
        align-items: center;
        gap: 18px;
        padding: 14px 18px;
        border-radius: 14px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .jogo-meta {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding-right: 12px;
        border-right: 1px solid rgba(255,255,255,0.12);
        min-height: 58px;
    }

    .jogo-data {
        font-size: 0.95rem;
        font-weight: 700;
        opacity: 0.85;
        white-space: nowrap;
    }

    .jogo-status {
        font-size: 0.95rem;
        font-weight: 700;
        opacity: 0.75;
        text-transform: uppercase;
    }

    .jogo-times {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
    }

    .linha-time {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 24px;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .time {
        display: flex;
        align-items: center;
        gap: 10px;
