@{
    ViewData["Title"] = "Cadastro";
}

<section class="login-page">
    <div class="login-card">

        <div class="login-top">
            <div class="tag">Cadastro</div>
            <h1>Crie sua conta</h1>
            <p>Rapidinho — e já seguimos para as apostas 😄</p>
        </div>

        <div class="login-content">

            <div class="login-image">
                <img src="~/Img/meganapers.png" alt="Napers" />
            </div>

            <div class="painel_form">

                <form asp-controller="Conta"
                      asp-action="DadosCadastro"
                      method="post">
                      
                    <div class="campo">
                        <label>Nome completo</label>
                        <input type="text"
                               name="Nome"
                               placeholder="Digite seu nome completo"
                               autocomplete="name"
                               required />
                    </div>

                    <div class="campo">
                        <label>Data de nascimento</label>
                        <input type="date"
                               name="DataNascimento"
                               required />

                        <small id="erroIdade" style="color: red; display: none;">
                            Você precisa ter pelo menos 18 anos para participar.
                        </small>
                    </div>

                    <div class="campo">
                        <label>E-mail</label>
                        <input type="email"
                               name="Email"
                               placeholder="Digite seu e-mail"
                               autocomplete="email"
                               required />
                    </div>

                    <div class="campo">
                        <label>Escolha sua senha</label>
                        <input type="password"
                               name="Senha"
                               placeholder="Digite sua senha"
                               autocomplete="new-password"
                               required />
                    </div>

                    <div class="campo">
                        <label for="confirmarSenha">Confirme sua senha</label>
                        <input type="password"
                               id="confirmarSenha"
                               name="ConfirmarSenha"
                               placeholder="Digite novamente sua senha"
                               autocomplete="new-password"
                               required />

                        <small id="erroSenha" style="color: red; display: none;">
                            As senhas não coincidem.
                        </small>
                    </div>

                    <!-- EULA -->
                    <div class="campo termos">
                        <label class="checkbox_container">
                            <input type="checkbox" id="aceiteEula" name="AceitouEula" required />
                            <span>
                                Eu aceito os
                                <a href="javascript:void(0);" id="abrirEula">
                                    Termos e Condições
                                </a>
                            </span>
                        </label>
                    </div>

                    <button type="submit" class="btn-home btn-home--primary">
                        Concluir
                    </button>

                    <a asp-controller="Conta"
                       asp-action="Login"
                       class="btn-home btn-home--secondary">
                        Voltar pro login
                    </a>

                </form>

            </div>

        </div>
    </section>
</main>

<!-- MODAL EULA -->
<div id="modalEula" class="modal">
    <div class="modal_conteudo">
        <div class="modal_header">
            <h2>Termos e Condições</h2>
            <button id="fecharEula" class="btn_fechar">&times;</button>
        </div>

        <div class="modal_body">
            <iframe src="/conta/eula" frameborder="0"></iframe>
        </div>

        <div class="modal_footer">
            <button id="btnAceitarEula" class="btn btn_primario">
                Li e Aceito
            </button>
        </div>
    </div>
</div>

<style>
    .modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal_conteudo {
        background: #fff;
        width: 80%;
        max-width: 800px;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .modal_header,
    .modal_footer {
        padding: 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: black;
    }

    .modal_footer {
        border-top: 1px solid #eee;
        border-bottom: none;
        justify-content: flex-end;
    }

    .modal_body {
        flex: 1;
    }

        .modal_body iframe {
            width: 100%;
            height: 60vh;
        }

    .btn_fechar {
        background: none;
        border: none;
        font-size: 22px;
        cursor: pointer;
    }

    .campo.termos {
        display: flex;
        align-items: center;
    }

    .checkbox_container {
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

        .checkbox_container span {
            display: inline;
        }

        .checkbox_container a {
            display: inline;
        }
</style>

<script>
        document.addEventListener("DOMContentLoaded", function () {

        const form = document.querySelector(".form");
        const dataInput = document.getElementById("dataNascimento");
        const erroIdade = document.getElementById("erroIdade");

        const senhaInput = document.getElementById("senha");
        const confirmarSenhaInput = document.getElementById("confirmarSenha");
        const erroSenha = document.getElementById("erroSenha");

        const modal = document.getElementById("modalEula");
        const abrir = document.getElementById("abrirEula");
        const fechar = document.getElementById("fecharEula");
        const aceitar = document.getElementById("btnAceitarEula");
        const checkbox = document.getElementById("aceiteEula");

        // ===== MODAL =====
        abrir.addEventListener("click", function (e) {
            e.preventDefault();
            modal.style.display = "flex";
        });

        fechar.addEventListener("click", function () {
            modal.style.display = "none";
        });

        aceitar.addEventListener("click", function () {
            checkbox.checked = true;
            modal.style.display = "none";
        });

        window.addEventListener("click", function (e) {
            if (e.target === modal) {
                modal.style.display = "none";
            }
        });

        // ===== VALIDAÇÕES NO SUBMIT =====
        form.addEventListener("submit", function (e) {

            let valido = true;

            // ---- IDADE ----
            const dataNascimento = new Date(dataInput.value);
            const hoje = new Date();

            let idade = hoje.getFullYear() - dataNascimento.getFullYear();
            const mes = hoje.getMonth() - dataNascimento.getMonth();

            if (mes < 0 || (mes === 0 && hoje.getDate() < dataNascimento.getDate())) {
                idade--;
            }

            if (idade < 18) {
                erroIdade.style.display = "block";
                valido = false;
            } else {
                erroIdade.style.display = "none";
            }

            // ---- SENHA ----
            if (senhaInput.value !== confirmarSenhaInput.value) {
                erroSenha.style.display = "block";
                valido = false;
            } else {
                erroSenha.style.display = "none";
            }

            if (!valido) {
                e.preventDefault();
            }

        });

    });
</script>
    </div>
</section>


<style>

    /* ESCONDE FOOTER NESSA TELA */
    footer {
        display: none !important;
    }

    /* ===== LAYOUT BASE ===== */

    .login-page {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    body {
        overflow: hidden;
    }

    /* CARD */

    .login-card {
        width: 100%;
        max-width: 900px;
        padding: 40px;
        border-radius: 20px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
    }

    /* TOPO */

    .login-top h1 {
        margin-bottom: 8px;
    }

    .login-top p {
        opacity: 0.7;
        margin-bottom: 25px;
    }

    .tag {
        display: inline-block;
        background: #f5c518;
        color: black;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        margin-bottom: 10px;
    }

    /* GRID */

    .login-content {
        display: flex;
        gap: 40px;
        align-items: center;
    }

    /* IMAGEM */

    .login-image img {
        width: 100%;
        max-width: 300px;
        border-radius: 16px;
    }

    /* FORM */

    .login-form {
        flex: 1;
    }

    /* CAMPOS */

    .campo {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
    }

        .campo input {
            padding: 12px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.05);
            color: white;
            width: auto;
        }

    /* TERMOS */

    .termos {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 13px;
        margin-bottom: 15px;
    }

        .termos a {
            color: #3ea6ff;
            text-decoration: none;
        }

        .termos input[type="checkbox"] {
            accent-color: rgba(255,203,0,0.95);
        }

    /* BOTÕES (mesmo padrão do login) */

    .btn-home {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: .2s;
        margin-top: 10px;
    }

    .btn-home--primary {
        background: rgba(255,203,0,0.95);
        color: #0b0f17;
    }

        .btn-home--primary:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
        }

    .btn-home--secondary {
        background: rgba(255,255,255,0.08);
        color: white;
    }

    /* RESPONSIVO */

    @@media (max-width:768px) {
        .login-content

    {
        flex-direction: column;
        text-align: center;
    }

    .login-image img {
        max-width: 200px;
    }

    .login-card {
        padding: 25px;
    }

    .login-top h1 {
        font-size: 22px;
    }

    }
</style>
