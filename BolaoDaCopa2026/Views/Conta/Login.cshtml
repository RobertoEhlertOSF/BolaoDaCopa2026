@{
    ViewData["Title"] = "Login";
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

<section class="login-page">
    <div class="login-card">

        <div class="login-top">
            <h1>Sejam bem-vindos ao bolão Napers da copa do mundo de 2026!</h1>
            <p>Onde seu palpite vale muito!</p>
        </div>

        <div class="login-content">

            <div class="login-image">
                <img src="~/Img/meganapers.png" alt="Napers" />
            </div>

            <div class="login-form">
                <h2>Para o seu primeiro golaço, acesse sua conta:</h2>

                <form asp-controller="Conta"
                      asp-action="FazerLogin"
                      method="post">

                    <div class="campo">
                        <label>Email</label>
                        <input type="email"
                               name="Email"
                               placeholder="Digite seu e-mail"
                               autocomplete="email"
                               required />
                    </div>

                    <div class="campo">
                        <label>Senha</label>
                        <input type="password"
                               name="Senha"
                               placeholder="Digite sua senha"
                               autocomplete="current-password"
                               required />
                    </div>

                    <!-- BOTÃO PADRÃO DO SITE -->
                    <button type="submit"
                            class="btn-home btn-home--primary">
                        Entrar
                    </button>
                </form>

                <!-- MESMO PADRÃO DO INDEX -->
                <a asp-controller="Conta"
                   asp-action="Cadastro"
                   class="btn-home btn-home--primary"
                   style="margin-top: 12px;">
                    Novo? Crie uma conta
                </a>
            </div>

        </div>
    </div>
</section>

<style>
    /* ===== ESCONDER FOOTER SOMENTE NO LOGIN ===== */
    footer {
        display: none !important;
    }

    /* ===== LOGIN PAGE ===== */
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .login-card {
        width: 100%;
        max-width: 900px;
        padding: 40px;
        border-radius: 20px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
    }

    .login-top h1 {
        margin-bottom: 10px;
    }

    .login-top p {
        opacity: 0.7;
        margin-bottom: 30px;
    }

    .login-content {
        display: flex;
        gap: 40px;
        align-items: center;
    }

    .login-image img {
        width: 100%;
        max-width: 300px;
        border-radius: 16px;
    }

    .login-form {
        flex: 1;
    }

    .campo {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
    }

        .campo input {
            padding: 12px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.05);
            color: white;
        }

    .btn-home {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: .2s;
    }

    .btn-home--primary {
        background: rgba(255, 203, 0, 0.95);
        color: #0b0f17;
    }

        .btn-home--primary:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
            color: #0b0f17;
        }

    /* botão de baixo ocupa largura total */
    .login-form .btn-home {
        width: 100%;
        margin-top: 12px;
    }

    /* ===== RESPONSIVO ===== */

    @@media (max-width: 768px) {
        .login-content

    {
        flex-direction: column;
        text-align: center;
    }

    .login-image img {
        max-width: 200px;
    }

    .login-card {
        padding: 25px;
    }
    s
    .login-top h1 {
        font-size: 22px;
    }

    }
</style>