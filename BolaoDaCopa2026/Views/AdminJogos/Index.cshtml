@model List<BolaoDaCopa2026.Models.Jogo>

@functions {
    public string SiglaSelecao(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
            return "";

        nome = nome.Trim().ToUpper();

        return nome.Length >= 3
            ? nome.Substring(0, 3)
            : nome;
    }
}

<div class="admin-voltar">
    <a asp-controller="Home"
       asp-action="Index"
       class="btn-voltar">
        ← Voltar para o início
    </a>
</div>

<h1 class="mb-4">Painel de Jogos - Admin</h1>


<!-- PAINEL DE CONFIGURAÇÃO -->
<div class="admin-config">

    <h3>⚙ Configuração do Mata-mata</h3>

    <div class="admin-buttons">

        <a asp-controller="AdminJogos"
           asp-action="SegundaFase"
           class="btn-admin">
            2ª Fase
        </a>

        <a asp-controller="AdminJogos"
           asp-action="Oitavas"
           asp-action="Oitavas"
           class="btn-admin">
            Oitavas
        </a>

        <a asp-controller="AdminJogos"
           asp-action="Quartas"
           class="btn-admin">
            Quartas
        </a>

        <a asp-controller="AdminJogos"
           asp-action="SemiFinal"
           class="btn-admin">
            Semifinal
        </a>

        <a asp-controller="AdminJogos"
           asp-action="TerceiroLugar"
           class="btn-admin">
            3º Lugar
        </a>

        <a asp-controller="AdminJogos"
           asp-action="Final"
           class="btn-admin">
            Final
        </a>

        <a asp-controller="AdminJogos"
           asp-action="DefinirCampeao"
           class="btn-admin">
            🏆 Definir Campeão
        </a>

    </div>

</div>


<div class="admin-table-wrapper">

    <table class="table table-hover table-bordered align-middle admin-table">
        <thead>
            <tr>
                <th class="col-datahora">Data/Hora</th>
                <th>Fase</th>
                <th>Seleção A</th>
                <th>Placar</th>
                <th>Seleção B</th>
                <th>Status</th>
                <th>Ação</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var jogo in Model ?? new List<BolaoDaCopa2026.Models.Jogo>())
            {
                var statusClass = jogo.Status switch
                {
                    "Finalizado" => "text-success fw-bold",
                    "EmAndamento" => "text-warning fw-bold",
                    "Aguardando definição" => "text-secondary fw-bold",
                    _ => "text-muted"
                };

                <tr>
                    <td class="col-datahora">@jogo.DataHora.ToString("dd/MM HH:mm")</td>

                    <td>@jogo.Fase</td>

                    <!-- Seleção A -->
                    <td>
                        @if (jogo.SelecaoA != null)
                        {
                            <img src="@jogo.SelecaoA.BandeiraUrl"
                                 alt="@jogo.SelecaoA.Nome"
                                 width="24"
                                 class="me-1" />

                            @SiglaSelecao(jogo.SelecaoA.Nome)
                        }
                        else
                        {
                            <span class="text-muted">A definir</span>
                        }
                    </td>

                    <!-- Placar -->
                    <td>
                        @if (jogo.Status == "Finalizado")
                        {
                            <span class="badge bg-primary">
                                @jogo.GolsSelecaoA × @jogo.GolsSelecaoB
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <!-- Seleção B -->
                    <td>
                        @if (jogo.SelecaoB != null)
                        {
                            <img src="@jogo.SelecaoB.BandeiraUrl"
                                 alt="@jogo.SelecaoB.Nome"
                                 width="24"
                                 class="me-1" />

                            @SiglaSelecao(jogo.SelecaoB.Nome)
                        }
                        else
                        {
                            <span class="text-muted">A definir</span>
                        }
                    </td>

                    <td class="@statusClass">
                        @jogo.Status
                    </td>

                    <td>
                        <a asp-action="Editar"
                           asp-route-id="@jogo.Id"
                           class="btn-atualizar">
                            Atualizar
                        </a>
                    </td>

                </tr>
            }
        </tbody>

    </table>

</div>



<style>

    footer {
        display: none !important;
    }

    /* ============================= */
    /* BOTÃO VOLTAR (PADRÃO DO SITE) */
    /* ============================= */

    .admin-voltar {
        margin-bottom: 16px;
    }

    .btn-voltar {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 10px;
        background: rgba(255,203,0,0.95);
        color: #0b0f17;
        text-decoration: none;
        font-weight: 800;
        transition: filter .2s ease, transform .1s ease;
    }

        .btn-voltar:hover {
            filter: brightness(1.05);
            transform: translateX(-2px);
            color: #0b0f17;
            text-decoration: none;
        }


    /* ============================= */
    /* BOTÕES DO PAINEL ADMIN       */
    /* ============================= */

    .admin-config {
        margin: 10px 0 25px;
    }

        .admin-config h3 {
            margin-bottom: 10px;
            font-size: 18px;
            color: #fff;
            opacity: .9;
        }

    .admin-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-admin {
        padding: 10px 16px;
        border-radius: 10px;
        background: rgba(255,203,0,0.95);
        color: #0b0f17;
        font-weight: 800;
        text-decoration: none;
        transition: filter .2s ease, transform .1s ease;
    }

        .btn-admin:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
            color: #0b0f17;
            text-decoration: none;
        }


    /* ============================= */
    /* TABELA                        */
    /* ============================= */

    .admin-table-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: 18px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 10px 30px rgba(0,0,0,0.18);
    }

        .admin-table-wrapper table {
            min-width: 750px;
            margin-bottom: 0;
        }

    .admin-table {
        border-collapse: separate !important;
        border-spacing: 0;
        overflow: hidden;
        background: transparent;
    }

        .admin-table thead th {
            color: rgba(255,255,255,0.95);
            background: rgba(255,255,255,0.06);
            border-bottom: 1px solid rgba(255,255,255,0.10);
            border-right: 1px solid rgba(255,255,255,0.08);
            padding: 16px 14px;
            font-size: 0.95rem;
            font-weight: 800;
            white-space: nowrap;
        }

            .admin-table thead th:last-child {
                border-right: none;
            }

        .admin-table tbody td {
            color: rgba(255,255,255,0.82);
            background: transparent;
            border-top: 1px solid rgba(255,255,255,0.08);
            border-right: 1px solid rgba(255,255,255,0.06);
            padding: 14px;
            vertical-align: middle;
        }

            .admin-table tbody td:last-child {
                border-right: none;
            }

        .admin-table tbody tr:first-child td {
            border-top: none;
        }

        .admin-table tbody tr:hover td {
            background: rgba(255,255,255,0.04);
            transition: background-color 0.2s ease;
        }

    .col-datahora {
        white-space: nowrap;
    }

    /* botão atualizar */

    .btn-atualizar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        border-radius: 10px;
        background: rgba(255,203,0,0.95);
        color: #0b0f17;
        font-weight: 800;
        text-decoration: none;
        transition: filter .2s ease, transform .1s ease;
        border: none;
    }

        .btn-atualizar:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
            color: #0b0f17;
            text-decoration: none;
        }

    /* badges */

    .badge {
        font-size: 1rem;
        padding: 0.4em 0.7em;
    }

    /* bandeiras */

    img {
        vertical-align: middle;
        border-radius: 3px;
        max-height: 24px;
        margin-right: 6px;
    }


    /* ============================= */
    /* Telas menores                */
    /* ============================= */

    @@media (max-width:768px) {

        h1 {
            font-size: 28px;
        }

        .admin-buttons {
            flex-wrap: nowrap;
            overflow-x: auto;
            padding-bottom: 6px;
        }

        .btn-admin {
            white-space: nowrap;
            font-size: 14px;
            padding: 8px 14px;
        }
    }

</style>